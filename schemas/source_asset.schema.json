{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tsao.dev/schemas/source_asset.schema.json",
  "title": "TSAO source asset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "path",
    "sha256",
    "bytes",
    "specialist",
    "artifact_class",
    "license_scope"
  ],
  "properties": {
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*\\.\\./).+$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "bytes": {"type": "integer", "minimum": 0},
    "specialist": {
      "enum": ["master", "process-general", "epdm", "poe", "polymer-general"]
    },
    "artifact_class": {
      "enum": ["PUBLIC_SOURCE", "GENERATED_REPORT", "CONTROLLED_BINARY"]
    },
    "license_scope": {
      "enum": [
        "PROJECT_OWNED_OR_COMPATIBLE",
        "PROJECT_CONTROLLED",
        "UPSTREAM_OR_FIXTURE_BINARY"
      ]
    }
  }
}
