{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tsao.dev/schemas/project.schema.json",
  "title": "TSAO project manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["project_id", "title", "version", "domain", "subskills", "technical_approval_status", "gates"],
  "properties": {
    "project_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "domain": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "subskills": {"type": "array", "items": {"enum": ["epdm", "poe", "polymer-general"]}, "uniqueItems": true},
    "technical_approval_status": {"const": "NOT_EVALUATED"},
    "gates": {
      "type": "array",
      "minItems": 19,
      "maxItems": 19,
      "items": {"$ref": "gate.schema.json"}
    }
  }
}
