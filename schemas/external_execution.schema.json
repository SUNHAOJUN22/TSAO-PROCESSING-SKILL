{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://tsao.dev/schemas/external_execution.schema.json",
  "title":"TSAO external execution handoff",
  "type":"object",
  "additionalProperties":false,
  "required":["handoff_id","activity","reason","qualified_role","inputs","acceptance_criteria","status","evidence_ids"],
  "properties":{
    "handoff_id":{"type":"string","minLength":1},
    "activity":{"type":"string","minLength":1},
    "reason":{"type":"string","minLength":1},
    "qualified_role":{"type":"string","minLength":1},
    "inputs":{"type":"array","items":{"type":"string"}},
    "acceptance_criteria":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "status":{"enum":["REQUIRES_EXTERNAL_EXECUTION","SCHEDULED","EXECUTED","ACCEPTED","REJECTED"]},
    "evidence_ids":{"type":"array","items":{"type":"string"},"uniqueItems":true}
  }
}
