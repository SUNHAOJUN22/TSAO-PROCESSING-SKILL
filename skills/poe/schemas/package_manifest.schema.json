              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "requirement_trace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "bytes"
          ],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "conflict_ledger": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "bytes"
          ],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "evidence_ledger": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "bytes"
          ],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "model_passports": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "bytes"
          ],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  }
}
