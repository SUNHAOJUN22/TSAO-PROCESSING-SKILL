{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tsao.dev/skills/poe/schemas/package_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_id",
    "version",
    "files",
    "structured_records",
    "structured_record_integrity",
    "approvals"
  ],
  "properties": {
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "deliverable_id",
          "group",
          "path",
          "sha256",
          "bytes",
          "language",
          "content_type",
          "evidence_ids"
        ],
        "properties": {
          "deliverable_id": {
            "type": "string"
          },
          "group": {
            "enum": [
              "design_basis",
              "pfd",
              "material_energy_balance",
              "equipment",
              "instrument_control",
              "utilities",
              "model_validation",
              "acceptance"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 1
          },
          "language": {
            "type": "string"
          },
          "content_type": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "structured_records": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property_method",
        "process_case",
        "acceptance",
        "requirement_trace",
        "conflict_ledger",
        "evidence_ledger",
        "model_passports"
      ],
      "properties": {
        "property_method": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "process_case": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "acceptance": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "requirement_trace": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "conflict_ledger": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "evidence_ledger": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "model_passports": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        }
      }
    },
    "approvals": {
      "type": "object",
      "required": [
        "package_approver"
      ],
      "properties": {
        "package_approver": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "structured_record_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property_method",
        "process_case",
        "acceptance",
        "requirement_trace",
        "conflict_ledger",
        "evidence_ledger",
        "model_passports"
      ],
      "properties": {
        "property_method": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "bytes"
          ],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "process_case": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "bytes"
          ],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "acceptance": {
          "type": "object",
