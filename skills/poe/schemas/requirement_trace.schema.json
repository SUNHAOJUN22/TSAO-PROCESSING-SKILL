{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tsao.dev/skills/poe/schemas/requirement_trace.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_version",
    "requirements",
    "coverage",
    "technical_approval"
  ],
  "properties": {
    "trace_version": {
      "type": "string"
    },
    "technical_approval": {
      "const": "NOT_EVALUATED"
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registered",
        "total_identified"
      ],
      "properties": {
        "registered": {
          "type": "integer",
          "minimum": 1
        },
        "total_identified": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requirement_id",
          "source_locator",
          "criterion",
          "asset_ids",
          "verification_method",
          "status",
          "deviation",
          "approver",
          "gate",
          "evidence_state"
        ],
        "properties": {
          "requirement_id": {
            "type": "string",
            "pattern": "^POE-REQ-[0-9]{3}$"
          },
          "source_locator": {
            "type": "string",
            "minLength": 1
          },
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "asset_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^POE-ASSET-[0-9]{4}$"
            }
          },
          "verification_method": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "NOT_EVALUATED",
              "HOLD",
              "CONDITIONAL",
              "PASS",
              "FAIL"
            ]
          },
          "deviation": {
            "type": [
              "string",
              "null"
            ]
          },
          "approver": {
            "type": [
              "string",
              "null"
            ]
          },
          "gate": {
            "type": "string",
            "pattern": "^G([0-9]|1[0-8])$"
          },
          "evidence_state": {
            "enum": [
              "LOCATED_NOT_REQUALIFIED",
              "QUALIFIED",
              "REJECTED"
            ]
          }
        }
      }
    }
  }
}
