{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tsao.dev/skills/poe/schemas/process_case.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id","mode","components","streams","equipment","property_method","convergence","source_asset_sha256","acceptance_criteria"],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["steady","dynamic"]},
    "components": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "streams": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["stream_id","from","to","flow_kg_h","composition"], "properties": {"stream_id": {"type": "string"}, "from": {"type": "string"}, "to": {"type": "string"}, "flow_kg_h": {"type": "number", "minimum": 0}, "composition": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}}, "is_recycle": {"type": "boolean"}, "closed": {"type": "boolean"}}, "additionalProperties": false}},
    "equipment": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["equipment_id","type"], "properties": {"equipment_id": {"type": "string"}, "type": {"type": "string"}}, "additionalProperties": false}},
    "property_method": {"type": "object"},
    "convergence": {"type": "boolean"},
    "source_asset_sha256": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "controllers": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "valves": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "volumes": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "initial_conditions": {"type": "object", "minProperties": 1},
    "disturbances": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "dynamic_assets": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "claims": {"type": "object"},
    "mass_balance_tolerance_fraction": {"type": "number", "minimum": 0}
  },
  "allOf": [{"if": {"properties": {"mode": {"const": "dynamic"}}}, "then": {"required": ["dynamic_assets","controllers","valves","volumes","initial_conditions","disturbances"]}}]
}
